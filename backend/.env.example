# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/fittrack

# ── Security ──────────────────────────────────────────────────────────────────
# Minimum 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-secure-random-key-minimum-32-chars

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins.
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ── Food Search (USDA FoodData Central) ───────────────────────────────────────
# Free API key signup: https://fdc.nal.usda.gov/api-key-signup.html
# Without a key, DEMO_KEY is used (30 req/hr limit — fine for development).
# Get your free key to unlock full rate limits in production.
USDA_FDC_API_KEY=DEMO_KEY

# ── App ───────────────────────────────────────────────────────────────────────
# development | production | test
ENVIRONMENT=development
